---
import SearchModal from '../islands/SearchModal';
import type { Lang, Translations } from '../i18n';

interface Props {
  lang: Lang;
  t: Translations;
  otherLang: Lang;
  otherPath: string;
}

const { lang, t, otherLang, otherPath } = Astro.props;

const navItems = [
  { label: t.nav.dev, href: `/${lang}/category/dev/` },
  { label: t.nav.text, href: `/${lang}/category/text/` },
  { label: t.nav.image, href: `/${lang}/category/image/` },
  { label: t.nav.pdf, href: `/${lang}/category/pdf/` },
  { label: t.nav.crypto, href: `/${lang}/category/crypto/` },
  { label: t.nav.calculators, href: `/${lang}/category/calculators/` },
  { label: t.nav.life, href: `/${lang}/category/life/` },
];
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={`/${lang}/`} class="flex items-center gap-2 font-bold text-xl text-gray-900 no-underline">
      <span class="w-8 h-8 bg-zen-500 rounded-lg flex items-center justify-center text-white text-sm">T</span>
      ToolZen
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navItems.map(item => (
        <a href={item.href} class="px-3 py-2 text-sm text-gray-600 hover:text-zen-500 rounded-md hover:bg-zen-50 transition-colors no-underline">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href={`/${lang}/suggest/`} class="hidden md:inline-flex px-2.5 py-1 text-xs font-medium text-zen-600 hover:text-white bg-zen-50 hover:bg-zen-500 rounded-md transition-colors no-underline" title={t.footer.suggest}>
        💡 {t.footer.suggest}
      </a>
      <a href={otherPath} class="px-2.5 py-1 text-xs font-medium text-gray-500 hover:text-zen-500 bg-gray-100 hover:bg-zen-50 rounded-md transition-colors no-underline">
        {otherLang === 'zh' ? '中文' : 'EN'}
      </a>
      <SearchModal client:load />
    </div>
  </div>
</header>
