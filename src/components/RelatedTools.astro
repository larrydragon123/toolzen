---
import { getRelatedTools } from '../utils/tools';
import ToolCard from './ToolCard.astro';
import type { Lang, TranslationDict } from '../i18n';

export interface Props {
  current: string;
  lang: Lang;
  t: TranslationDict;
}

const { current, lang, t } = Astro.props;
const related = getRelatedTools(current, 4);
---

{related.length > 0 && (
  <section class="mt-12 pt-8 border-t border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">{t.relatedTools}</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {related.map((tool) => {
        const meta = t.tools[tool.slug] ?? tool;
        return (
          <ToolCard slug={tool.slug} title={meta.title} description={meta.description} lang={lang} />
        );
      })}
    </div>
  </section>
)}
