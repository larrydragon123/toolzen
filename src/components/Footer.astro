---
import type { Lang, Translations } from '../i18n';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;
---

<footer class="border-t border-gray-100 mt-20">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-sm text-gray-500">
        {t.footer.copyright}
      </div>
      <nav class="flex gap-6">
        <a href={`/${lang}/about/`} class="text-sm text-gray-500 hover:text-gray-700 no-underline">{t.footer.about}</a>
        <a href={`/${lang}/privacy/`} class="text-sm text-gray-500 hover:text-gray-700 no-underline">{t.footer.privacy}</a>
        <a href={`/${lang}/suggest/`} class="text-sm text-gray-500 hover:text-gray-700 no-underline">{t.footer.suggest}</a>
        <a href="mailto:dragon1254383552@gmail.com" class="text-sm text-gray-500 hover:text-gray-700 no-underline">{t.footer.contact}</a>
      </nav>
    </div>
  </div>
</footer>
