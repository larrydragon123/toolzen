---
import { TOOLS } from '../utils/tools';
import type { Lang, Translations } from '../i18n';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;
---

<div id="search" class="relative max-w-2xl mx-auto">
  <input
    type="text"
    id="tool-search"
    placeholder={t.nav.searchPlaceholder}
    class="w-full px-4 py-3 pl-10 rounded-xl border border-gray-200 focus:border-zen-500 focus:ring-2 focus:ring-zen-100 outline-none transition-all text-gray-900"
  />
  <svg class="absolute left-3 top-3.5 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
  </svg>

  <div id="search-suggest" class="hidden mt-3 p-4 bg-zen-50 border border-zen-100 rounded-xl text-center">
    <p class="text-sm text-gray-500 mb-2">{t.nav.searchEmpty}</p>
    <a href={`/${lang}/suggest/`} class="inline-block px-4 py-1.5 text-sm font-medium text-zen-500 hover:text-white bg-white hover:bg-zen-500 border border-zen-200 rounded-lg transition-colors no-underline">
      {t.nav.searchSuggest}
    </a>
  </div>
</div>

<script>
  const input = document.getElementById('tool-search') as HTMLInputElement;
  const suggest = document.getElementById('search-suggest')!;
  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    const cards = document.querySelectorAll('[data-tool-card]');
    let visibleCount = 0;
    cards.forEach(card => {
      const name = (card.getAttribute('data-tool-card') || '').toLowerCase();
      const match = name.includes(q);
      (card as HTMLElement).style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });
    if (q && visibleCount === 0) {
      suggest.classList.remove('hidden');
    } else {
      suggest.classList.add('hidden');
    }
  });
</script>
