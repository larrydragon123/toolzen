---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getTool } from '../utils/tools';
import { generateToolSEOMeta } from '../utils/seo';
import CaseConverter from '../islands/CaseConverter';

const tool = getTool('case-converter')!;
const seo = generateToolSEOMeta(tool);
---

<BaseLayout title={seo.title} description={tool.description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: '文本工具', href: '/category/text/' },
      { label: tool.title },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">在线{tool.title}工具</h1>
    <p class="text-gray-500 mb-8">{tool.description}</p>

    <CaseConverter client:load />

    <section class="mt-12 prose max-w-none">
      <h2 class="text-xl font-semibold text-gray-900">如何使用{tool.title}工具</h2>
      <p class="text-gray-600">在输入框中粘贴或输入您要转换的文本，然后点击对应的转换按钮即可。支持<strong>英文大写</strong>（全部转为大写字母）、<strong>英文小写</strong>（全部转为小写字母）、<strong>首字母大写</strong>（每个单词首字母大写）、<strong>简体转繁体</strong>和<strong>繁体转简体</strong>（中文字符转换）、以及<strong>反转大小写</strong>（大写变小写，小写变大写）。转换结果在下方展示，点击Copy按钮可一键复制。所有处理均在浏览器本地完成，您的数据不会上传到任何服务器。</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">支持的转换类型</h3>
      <ul class="text-gray-600 space-y-1">
        <li><strong>英文大写</strong> — 将全部英文字母转为大写形式（UPPERCASE）</li>
        <li><strong>英文小写</strong> — 将全部英文字母转为小写形式（lowercase）</li>
        <li><strong>首字母大写</strong> — 将每个单词的首字母大写（Title Case）</li>
        <li><strong>简体→繁体</strong> — 将中文简体字转为对应的繁体字</li>
        <li><strong>繁体→简体</strong> — 将中文繁体字转为对应的简体字</li>
        <li><strong>反转大小写</strong> — 将大写字母转为小写，小写字母转为大写</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">常见问题</h3>
      <div class="space-y-4">
        <div>
          <h4 class="font-medium text-gray-800">繁简体转换覆盖所有汉字吗？</h4>
          <p class="text-gray-600">本工具内置了常用繁简体对照表，覆盖日常使用中差异较大的汉字。对于常见文本的繁简体互转已足够使用，但可能无法覆盖所有生僻字和特殊用字。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">首字母大写和每个单词首字母有什么区别？</h4>
          <p class="text-gray-600">这两个功能实际上效果相同，都是将每个英文单词的首字母转为大写。适用场景包括标题格式化、人名格式化等。注意连字符和缩写词可能需要手动调整。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">转换结果可以保存吗？</h4>
          <p class="text-gray-600">转换完成后，点击"Copy"按钮即可将结果复制到剪贴板，然后粘贴到您需要的任何地方（Word文档、代码编辑器、聊天窗口等）。本工具不提供在线保存功能以保护您的隐私。</p>
        </div>
      </div>
    </section>

    <RelatedTools current="case-converter" />
  </div>

  {seo.script.map(s => <script type={s.type} set:html={s.innerHTML}></script>)}
</BaseLayout>
