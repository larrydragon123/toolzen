---
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin - ToolZen</title>
  <style>
    @import "tailwindcss";

    @theme {
      --color-zen-50: #eff6ff;
      --color-zen-100: #dbeafe;
      --color-zen-200: #bfdbfe;
      --color-zen-500: #2563eb;
      --color-zen-600: #1d4ed8;
      --color-zen-700: #1e40af;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f9fafb;
    }

    .card { background: #fff; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
    .empty-state { padding: 80px 20px; text-align: center; color: #9ca3af; }
    .empty-state .icon { font-size: 3rem; margin-bottom: 12px; opacity: .5; }

    .toast {
      position: fixed; bottom: 24px; right: 24px;
      background: #111827; color: #fff; padding: 10px 22px;
      border-radius: 10px; font-size: .84rem; z-index: 100;
      box-shadow: 0 4px 16px rgba(0,0,0,.15);
      animation: toast-in .25s ease;
    }
    @keyframes toast-in {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .badge { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: .7rem; font-weight: 500; }
    .badge-pending  { background: #fef3c7; color: #92400e; }
    .badge-reviewed { background: #dbeafe; color: #1e40af; }
    .badge-done     { background: #d1fae5; color: #065f46; }
  </style>
</head>
<body class="min-h-screen">
  <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg text-gray-900 no-underline">
        <span class="w-7 h-7 bg-zen-500 rounded-lg flex items-center justify-center text-white text-xs">T</span>
        ToolZen <span class="text-xs font-normal text-gray-400 ml-1">Admin</span>
      </a>
      <button id="logout-btn-top" class="text-sm text-gray-500 hover:text-gray-700 bg-transparent border-0 cursor-pointer hidden">
        Logout
      </button>
    </div>
  </header>

  <div id="login" class="flex items-center justify-center" style="min-height:calc(100vh - 56px)">
    <div class="card p-10 w-full max-w-sm mx-4">
      <div class="text-center mb-8">
        <div class="text-3xl mb-3">Admin</div>
        <h1 class="text-lg font-semibold text-gray-900">Admin Login</h1>
        <p class="text-sm text-gray-400 mt-1">Enter password to view tool suggestions</p>
      </div>
      <input
        type="password"
        id="pw"
        placeholder="Admin password"
        autofocus
        class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm outline-none focus:border-zen-500 focus:ring-2 focus:ring-zen-100 transition mb-3"
      />
      <div id="login-error" class="text-red-500 text-xs mb-3 min-h-[18px]"></div>
      <button id="login-btn" class="w-full py-2.5 bg-zen-500 text-white text-sm font-medium rounded-lg hover:bg-zen-600 transition cursor-pointer border-0">
        Login
      </button>
    </div>
  </div>

  <div id="dash" class="hidden max-w-5xl mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-xl font-bold text-gray-900">Tool Suggestions</h1>
        <p class="text-sm text-gray-400 mt-1">Feature requests submitted through the suggestion form</p>
      </div>
      <button id="refresh-btn" class="px-4 py-2 text-sm bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition cursor-pointer">
        Refresh
      </button>
    </div>

    <div class="flex gap-3 mb-6 flex-wrap" id="stats"></div>
    <div id="content"></div>
  </div>

  <script is:inline>
    let suggestions = [];
    let password = sessionStorage.getItem('admin_pw') || '';

    const loginEl = document.getElementById('login');
    const dashEl = document.getElementById('dash');
    const pwEl = document.getElementById('pw');
    const loginBtn = document.getElementById('login-btn');
    const logoutBtn = document.getElementById('logout-btn-top');
    const refreshBtn = document.getElementById('refresh-btn');
    const loginErrorEl = document.getElementById('login-error');
    const statsEl = document.getElementById('stats');
    const contentEl = document.getElementById('content');

    loginBtn.addEventListener('click', function() {
      password = pwEl.value.trim();
      if (password) fetchSuggestions();
    });

    pwEl.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        password = pwEl.value.trim();
        if (password) fetchSuggestions();
      }
    });

    refreshBtn.addEventListener('click', fetchSuggestions);
    logoutBtn.addEventListener('click', logout);

    async function fetchSuggestions() {
      loginErrorEl.textContent = '';
      contentEl.innerHTML = '<div class="empty-state"><div class="icon">...</div><p>Loading...</p></div>';

      try {
        const res = await fetch('/api/suggestions', {
          headers: { Authorization: 'Bearer ' + password },
        });
        if (!res.ok) {
          loginErrorEl.textContent = 'Wrong password. Please try again.';
          contentEl.innerHTML = '';
          return;
        }
        const data = await res.json();
        sessionStorage.setItem('admin_pw', password);
        loginEl.classList.add('hidden');
        dashEl.classList.remove('hidden');
        logoutBtn.classList.remove('hidden');
        suggestions = Array.isArray(data.suggestions) ? data.suggestions : [];
        render();
      } catch (e) {
        loginErrorEl.textContent = 'Network error. Please check the connection.';
        contentEl.innerHTML = '';
      }
    }

    function render() {
      let pending = 0;
      let reviewed = 0;
      let done = 0;

      for (const suggestion of suggestions) {
        const status = suggestion.status || 'pending';
        if (status === 'reviewed') reviewed++;
        else if (status === 'implemented') done++;
        else pending++;
      }

      statsEl.innerHTML =
        '<div class="card px-5 py-3 text-sm text-gray-500">All <b class="text-xl text-gray-900 ml-1">' + suggestions.length + '</b></div>' +
        '<div class="card px-5 py-3 text-sm text-gray-500">Pending <b class="text-xl text-gray-900 ml-1">' + pending + '</b></div>' +
        '<div class="card px-5 py-3 text-sm text-gray-500">Reviewed <b class="text-xl text-gray-900 ml-1">' + reviewed + '</b></div>' +
        '<div class="card px-5 py-3 text-sm text-gray-500">Implemented <b class="text-xl text-gray-900 ml-1">' + done + '</b></div>';

      if (suggestions.length === 0) {
        contentEl.innerHTML = '<div class="empty-state"><div class="icon">Empty</div><p class="text-lg font-medium text-gray-400 mb-1">No suggestions yet</p><p class="text-sm text-gray-300">Suggestions submitted by users will appear here.</p></div>';
        return;
      }

      contentEl.innerHTML = suggestions.map(renderSuggestion).join('');
    }

    function renderSuggestion(suggestion) {
      const status = suggestion.status || 'pending';
      const badgeHtml = status === 'implemented'
        ? '<span class="badge badge-done">Implemented</span>'
        : status === 'reviewed'
          ? '<span class="badge badge-reviewed">Reviewed</span>'
          : '<span class="badge badge-pending">Pending</span>';
      const d = new Date(suggestion.createdAt);
      const dateStr = d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
      const copyText = (suggestion.toolName || '') + ' - ' + (suggestion.description || '');

      return '' +
        '<div class="card p-5 mb-3" style="display:grid;grid-template-columns:1fr auto;gap:16px;align-items:start">' +
          '<div>' +
            '<div class="font-semibold text-gray-900 flex items-center gap-2 flex-wrap">' + escHtml(suggestion.toolName || '') + ' ' + badgeHtml + '</div>' +
            '<div class="text-gray-600 text-sm mt-2 leading-relaxed" style="word-break:break-word">' + escHtml(suggestion.description || '') + '</div>' +
            '<div class="flex gap-4 mt-3 text-xs text-gray-400 flex-wrap">' +
              '<span>' + dateStr + '</span>' +
              (suggestion.email ? '<span>' + escHtml(suggestion.email) + '</span>' : '') +
              '<span>IP ' + escHtml(suggestion.ip || '') + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="flex flex-col items-end gap-2">' +
            '<select class="status-select text-xs px-2 py-1 rounded-lg border border-gray-200 bg-white cursor-pointer" data-id="' + escAttr(suggestion.id || '') + '">' +
              '<option value="pending"' + (status === 'pending' ? ' selected' : '') + '>Pending</option>' +
              '<option value="reviewed"' + (status === 'reviewed' ? ' selected' : '') + '>Reviewed</option>' +
              '<option value="implemented"' + (status === 'implemented' ? ' selected' : '') + '>Implemented</option>' +
            '</select>' +
            '<button class="copy-btn border-0 bg-transparent text-xs text-gray-400 hover:text-gray-600 cursor-pointer py-1" data-text="' + escAttr(copyText) + '">Copy</button>' +
            '<button class="del-btn border-0 bg-transparent text-xs text-red-400 hover:text-red-600 cursor-pointer py-1" data-id="' + escAttr(suggestion.id || '') + '">Delete</button>' +
          '</div>' +
        '</div>';
    }

    function pad(n) { return n < 10 ? '0' + n : String(n); }

    contentEl.addEventListener('click', function(e) {
      const target = e.target;
      const copyBtn = target.closest('.copy-btn');
      if (copyBtn) {
        copyText(copyBtn.getAttribute('data-text') || '');
        return;
      }
      const delBtn = target.closest('.del-btn');
      if (delBtn) deleteSuggestion(delBtn.getAttribute('data-id') || '');
    });

    contentEl.addEventListener('change', function(e) {
      const target = e.target;
      if (target.classList.contains('status-select')) {
        changeStatus(target.getAttribute('data-id') || '', target.value);
      }
    });

    async function changeStatus(id, status) {
      try {
        const res = await fetch('/api/suggestions', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + password },
          body: JSON.stringify({ id, status }),
        });
        if (res.ok) {
          const item = suggestions.find(function(suggestion) { return suggestion.id === id; });
          if (item) item.status = status;
          toast('Status updated');
        } else {
          toast('Update failed');
          render();
        }
      } catch (e) {
        toast('Network error');
        render();
      }
    }

    async function deleteSuggestion(id) {
      if (!confirm('Delete this suggestion?')) return;
      try {
        const res = await fetch('/api/suggestions?id=' + encodeURIComponent(id), {
          method: 'DELETE',
          headers: { Authorization: 'Bearer ' + password },
        });
        if (res.ok) {
          suggestions = suggestions.filter(function(suggestion) { return suggestion.id !== id; });
          render();
          toast('Deleted');
        } else {
          toast('Delete failed');
        }
      } catch (e) {
        toast('Network error');
      }
    }

    function copyText(text) {
      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(function() { toast('Copied'); });
      }
    }

    function toast(msg) {
      const el = document.createElement('div');
      el.className = 'toast';
      el.textContent = msg;
      document.body.appendChild(el);
      setTimeout(function() { el.remove(); }, 2200);
    }

    function escHtml(str) {
      const el = document.createElement('span');
      el.textContent = String(str);
      return el.innerHTML;
    }

    function escAttr(str) {
      return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function logout() {
      sessionStorage.removeItem('admin_pw');
      password = '';
      suggestions = [];
      loginEl.classList.remove('hidden');
      dashEl.classList.add('hidden');
      logoutBtn.classList.add('hidden');
      pwEl.value = '';
      loginErrorEl.textContent = '';
    }

    if (password) fetchSuggestions();
  </script>
</body>
</html>
