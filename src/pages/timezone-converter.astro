---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getTool } from '../utils/tools';
import { generateToolSEOMeta } from '../utils/seo';
import TimezoneConverter from '../islands/TimezoneConverter';

const tool = getTool('timezone-converter')!;
const seo = generateToolSEOMeta(tool);
---

<BaseLayout title={seo.title} description={tool.description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: '计算器', href: '/category/calculators/' },
      { label: tool.title },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">在线{tool.title}工具</h1>
    <p class="text-gray-500 mb-8">{tool.description}</p>

    <TimezoneConverter client:load />

    <section class="mt-12 prose max-w-none">
      <h2 class="text-xl font-semibold text-gray-900">如何使用{tool.title}工具</h2>
      <p class="text-gray-600">时区转换器实时显示全球多个时区的当前时间，支持秒级刷新。点击时区按钮即可添加或移除对应城市的时钟卡片。您还可以使用<strong>自定义时间</strong>功能选择一个特定时间，查看其在各个时区对应的本地时间，非常适用于规划跨国电话会议、远程团队协作和国际旅行安排。</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">支持的主要时区</h3>
      <ul class="text-gray-600 space-y-1">
        <li><strong>亚洲</strong>：北京 (UTC+8)、东京 (UTC+9)、新加坡 (UTC+8)、孟买 (UTC+5:30)</li>
        <li><strong>欧洲</strong>：伦敦 (UTC+0)、巴黎 (UTC+1)、莫斯科 (UTC+3)</li>
        <li><strong>北美</strong>：纽约 (UTC-5)、洛杉矶 (UTC-8)</li>
        <li><strong>大洋洲</strong>：悉尼 (UTC+11)</li>
        <li><strong>中东</strong>：迪拜 (UTC+4)</li>
        <li><strong>标准</strong>：UTC (UTC+0)</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">常见问题</h3>
      <div class="space-y-4">
        <div>
          <h4 class="font-medium text-gray-800">时区显示的时间准确吗？</h4>
          <p class="text-gray-600">时区时间基于您设备的系统时间进行计算，精确到秒。工具使用标准时区偏移量显示各地时间。实际时间可能因夏令时（DST）略有差异，本工具显示的是标准时区时间。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">如何使用自定义时间规划会议？</h4>
          <p class="text-gray-600">点击"自定义时间"旁边的输入框，选择您期望的本地时间（当前时区），然后查看其他时区对应的卡片。所有卡片会自动更新为所选时间在各时区的对应时刻，方便您寻找所有参会者都方便的时间段。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">日期差标签的含义是什么？</h4>
          <p class="text-gray-600">某些时区卡片上会显示"+1天"或"-1天"的标签，表示该时区的日期与您当前时区不在同一天。这在跨太平洋时区对比时很常见，例如北京时间上午9点时，纽约可能还是前一天的晚上。</p>
        </div>
      </div>
    </section>

    <RelatedTools current="timezone-converter" />
  </div>

  {seo.script.map(s => <script type={s.type} set:html={s.innerHTML}></script>)}
</BaseLayout>
