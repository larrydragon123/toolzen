---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getTool } from '../utils/tools';
import { generateToolSEOMeta } from '../utils/seo';
import QrCodeGenerator from '../islands/QrCodeGenerator';

const tool = getTool('qr-code')!;
const seo = generateToolSEOMeta(tool);
---

<BaseLayout title={seo.title} description={tool.description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: '图片工具', href: '/category/image/' },
      { label: tool.title },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">在线{tool.title}工具</h1>
    <p class="text-gray-500 mb-8">{tool.description}</p>

    <QrCodeGenerator client:load />

    <section class="mt-12 prose max-w-none">
      <h2 class="text-xl font-semibold text-gray-900">如何使用{tool.title}工具</h2>
      <p class="text-gray-600">二维码（QR Code，即Quick Response Code）是一种可被机器快速识别的二维条码，能够存储URL、文本、联系方式等信息。使用本工具，您只需输入需要编码的内容（如网址链接、纯文本或联系方式），选择尺寸和颜色，点击"Generate"按钮即可生成高清二维码图片。所有生成过程均在浏览器本地完成，您的数据不会上传到任何服务器。</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">常见问题</h3>
      <div class="space-y-4">
        <div>
          <h4 class="font-medium text-gray-800">什么是二维码？</h4>
          <p class="text-gray-600">二维码（QR Code）是由日本Denso Wave公司于1994年发明的一种矩阵式二维条码。它使用黑白相间的几何图形来存储数据，可通过智能手机摄像头或专用扫描设备快速读取。相比传统的一维条形码，二维码能存储更多信息，且支持360度全方位扫描。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">二维码可以存储哪些内容？</h4>
          <p class="text-gray-600">二维码可以存储多种类型的数据，包括网址链接（URL）、纯文本、电子名片（vCard）、WiFi连接信息、电话号码、电子邮件地址和地理位置等。理论上，一个二维码最多可存储约4296个字母数字字符或7089个数字。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">生成的数据会上传到服务器吗？</h4>
          <p class="text-gray-600">不会。ToolZen所有工具都在浏览器本地运行，二维码的生成过程完全在您的设备上完成。您输入的任何内容都不会被上传、存储或传输到远程服务器，确保您的数据隐私安全。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">二维码颜色可以自定义吗？背景色会影响扫描吗？</h4>
          <p class="text-gray-600">可以。本工具支持自定义前景色（二维码图案颜色）和背景色。但请注意，前景色和背景色之间需要保持足够的对比度（推荐深色前景配浅色背景），否则可能导致扫码设备无法正常识别。建议使用默认的黑白配色以获得最佳的扫描效果。</p>
        </div>
      </div>
    </section>

    <RelatedTools current="qr-code" />
  </div>

  {seo.script.map(s => <script type={s.type} set:html={s.innerHTML}></script>)}
</BaseLayout>
