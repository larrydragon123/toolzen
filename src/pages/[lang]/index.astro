---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import { TOOLS, CATEGORIES } from '../../utils/tools';
import { getDict } from '../../i18n';
import type { Lang } from '../../i18n';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);

const popularSlugs = ['json-formatter', 'base64', 'qr-code', 'image-compress', 'uuid-generator', 'word-counter'];
const popularTools = popularSlugs.map(s => TOOLS.find(tool => tool.slug === s)!).filter(Boolean);

const blogPosts = (await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout lang={lang} t={t} title={t.seo.homeTitle} description={t.seo.homeDesc}>
  <section class="max-w-4xl mx-auto px-4 pt-16 pb-12 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 tracking-tight">
      {t.home.hero}<span class="text-zen-500">{t.home.heroHighlight}</span>
    </h1>
    <p class="text-lg text-gray-500 mb-8 max-w-xl mx-auto">{t.home.subtitle}</p>
    <SearchBar lang={lang} t={t} />
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-xl font-semibold text-gray-900 mb-6">{t.home.popular}</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      {popularTools.map(tool => (
        <ToolCard slug={tool.slug} title={t.tools[tool.slug].title} description={t.tools[tool.slug].description} lang={lang} />
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-xl font-semibold text-gray-900 mb-6">{t.home.allCategories}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {CATEGORIES.map(cat => (
        <CategoryCard slug={cat.slug} title={t.categories[cat.slug].title} icon={cat.icon} description={t.categories[cat.slug].description} lang={lang} t={t} />
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-xl font-semibold text-gray-900 mb-6 text-center">{t.home.whyTitle}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="text-3xl mb-3">🔒</div>
        <h3 class="font-semibold text-gray-900 mb-2">{t.home.privacy.title}</h3>
        <p class="text-sm text-gray-500">{t.home.privacy.desc}</p>
      </div>
      <div class="text-center">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="font-semibold text-gray-900 mb-2">{t.home.speed.title}</h3>
        <p class="text-sm text-gray-500">{t.home.speed.desc}</p>
      </div>
      <div class="text-center">
        <div class="text-3xl mb-3">🆓</div>
        <h3 class="font-semibold text-gray-900 mb-2">{t.home.free.title}</h3>
        <p class="text-sm text-gray-500">{t.home.free.desc}</p>
      </div>
    </div>
  </section>

  {blogPosts.length > 0 && (
    <section class="max-w-4xl mx-auto px-4 py-12 border-t border-gray-100">
      <div class="flex items-end justify-between mb-6">
        <div>
          <h2 class="text-xl font-semibold text-gray-900">{t.home.blogTitle}</h2>
          <p class="text-sm text-gray-500 mt-1">{t.home.blogSubtitle}</p>
        </div>
        <a href={`/${lang}/blog/`} class="text-sm text-zen-500 hover:text-zen-600 no-underline whitespace-nowrap">
          {t.home.blogViewAll}
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {blogPosts.map(post => (
          <a href={`/${lang}/blog/${post.id.split('/').slice(1).join('/')}/`} class="block p-5 border border-gray-200 rounded-xl hover:border-zen-200 hover:shadow-sm transition-all no-underline">
            <time class="text-xs text-gray-400" datetime={post.data.date.toISOString().split('T')[0]}>
              {post.data.date.toISOString().split('T')[0]}
            </time>
            <h3 class="font-semibold text-gray-900 mt-1 mb-1 line-clamp-2">{post.data.title}</h3>
            <p class="text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="max-w-4xl mx-auto px-4 py-12 border-t border-gray-100">
    <h2 class="text-xl font-semibold text-gray-900 mb-6">{t.home.faqTitle}</h2>
    <div class="space-y-4">
      {t.home.faq.map(item => (
        <div>
          <h3 class="font-medium text-gray-800">{item.q}</h3>
          <p class="text-gray-600 text-sm mt-1">{item.a}</p>
        </div>
      ))}
    </div>
  </section>

  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: lang === 'zh' ? 'ToolZen - 免费在线工具' : 'ToolZen - Free Online Tools',
      url: `https://tool-zen.com/${lang}/`,
      description: t.seo.homeDesc,
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `https://tool-zen.com/${lang}/?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    })}></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'ToolZen',
      url: 'https://tool-zen.com',
      logo: 'https://tool-zen.com/favicon.svg',
      description: t.seo.homeDesc,
      sameAs: [],
    })}></script>
  </slot>
</BaseLayout>
