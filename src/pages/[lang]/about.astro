---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDict } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
---

<BaseLayout lang={lang} t={t} title={t.seo.aboutTitle} description={t.seo.aboutDesc}>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">{t.about.h1}</h1>
    <div class="prose max-w-none text-gray-600 space-y-4">
      <p>{t.about.p1}</p>
      <p>{t.about.p2}</p>
      <p>{t.about.p3}</p>
      <h2 class="text-xl font-semibold text-gray-900 mt-8">{t.about.contactTitle}</h2>
      <p>{t.about.contact} <a href="mailto:hello@toolzen.com">hello@toolzen.com</a></p>
    </div>
  </div>
</BaseLayout>
