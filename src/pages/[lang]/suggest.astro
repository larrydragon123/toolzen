---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getDict } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
const pageTitle = lang === 'zh'
  ? '建议工具 | ToolZen'
  : 'Suggest a Tool | ToolZen';
const pageDesc = lang === 'zh'
  ? '告诉我们你还想要什么在线工具，我们会尽快评估添加'
  : 'Tell us what online tools you need — we will evaluate and add them soon';
---

<BaseLayout lang={lang} t={t} title={pageTitle} description={pageDesc}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: t.breadcrumbHome, href: `/${lang}/` },
      { label: t.suggest.title },
    ]} lang={lang} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">{t.suggest.title}</h1>
    <p class="text-gray-500 mb-8">{t.suggest.subtitle}</p>

    <form id="suggest-form"
      data-submitting={t.suggest.submitting}
      data-success={t.suggest.success}
      data-error={t.suggest.error}
      class="space-y-5"
    >
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{t.suggest.toolName} <span class="text-red-500">*</span></label>
        <input
          type="text"
          name="toolName"
          required
          placeholder={t.suggest.toolNamePlaceholder}
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-zen-500 focus:border-zen-500 outline-none transition text-sm"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{t.suggest.description} <span class="text-red-500">*</span></label>
        <textarea
          name="description"
          required
          rows="4"
          placeholder={t.suggest.descriptionPlaceholder}
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-zen-500 focus:border-zen-500 outline-none transition text-sm resize-y"
        ></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{t.suggest.email}</label>
        <input
          type="email"
          name="email"
          placeholder={t.suggest.emailPlaceholder}
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-zen-500 focus:border-zen-500 outline-none transition text-sm"
        />
      </div>

      <button
        type="submit"
        id="submit-btn"
        data-label={t.suggest.submit}
        class="w-full py-3 bg-zen-500 text-white font-medium rounded-lg hover:bg-zen-600 transition-colors cursor-pointer"
      >
        {t.suggest.submit}
      </button>

      <p id="result-msg" class="text-center text-sm hidden"></p>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('suggest-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const msg = document.getElementById('result-msg') as HTMLParagraphElement;
  const origLabel = btn.dataset.label!;
  const submittingLabel = form.dataset.submitting!;
  const successMsg = form.dataset.success!;
  const errorMsg = form.dataset.error!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = submittingLabel;
    msg.classList.add('hidden');

    try {
      const fd = new FormData(form);
      const res = await fetch('/api/suggest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          toolName: fd.get('toolName'),
          description: fd.get('description'),
          email: fd.get('email') || null,
        }),
      });

      if (res.ok) {
        msg.textContent = successMsg;
        msg.className = 'text-center text-sm text-green-600';
        form.reset();
      } else {
        throw new Error('Failed');
      }
    } catch {
      msg.textContent = errorMsg;
      msg.className = 'text-center text-sm text-red-500';
    } finally {
      btn.disabled = false;
      btn.textContent = origLabel;
      msg.classList.remove('hidden');
    }
  });
</script>
