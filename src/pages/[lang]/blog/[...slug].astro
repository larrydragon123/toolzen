---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection, render } from 'astro:content';
import { getDict } from '../../../i18n';
import type { Lang } from '../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: {
      lang: post.id.split('/')[0],
      slug: post.id.split('/').slice(1).join('/').replace(/\.md$/, ''),
    },
  }));
}

const { lang, slug } = Astro.params;
const t = getDict(lang as Lang);
const id = `${lang}/${slug}`;
const posts = await getCollection('blog', ({ id: pid }) => pid === id);
const post = posts[0];

if (!post) return Astro.redirect(`/${lang}/blog/`);

const { Content } = await render(post);
const pageTitle = `${post.data.title} | ToolZen`;
const pageDesc = post.data.description;

const allPosts = await getCollection('blog', ({ id: pid }) => pid.startsWith(`${lang}/`) && pid !== id);
const relatedPosts = allPosts
  .filter(p => p.data.tags.some(tag => post.data.tags.includes(tag)))
  .slice(0, 3);
const recentPosts = relatedPosts.length >= 2 ? relatedPosts : allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout lang={lang as Lang} t={t} title={pageTitle} description={pageDesc}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: t.breadcrumbHome, href: `/${lang}/` },
      { label: lang === 'zh' ? '博客' : 'Blog', href: `/${lang}/blog/` },
      { label: post.data.title },
    ]} lang={lang as Lang} />

    <article>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{post.data.title}</h1>
      <div class="flex items-center gap-2 text-sm text-gray-400 mb-8">
        <span>{post.data.author}</span>
        <span>·</span>
        <time datetime={post.data.date.toISOString().split('T')[0]}>
          {post.data.date.toISOString().split('T')[0]}
        </time>
        {post.data.tags.map(tag => (
          <span class="px-2 py-0.5 bg-gray-100 rounded-full text-xs">{tag}</span>
        ))}
      </div>
      <div class="prose prose-gray max-w-none">
        <Content />
      </div>
    </article>

    {recentPosts.length > 0 && (
      <div class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">
          {lang === 'zh' ? '相关文章' : 'Related Articles'}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
          {recentPosts.map(rp => (
            <a href={`/${lang}/blog/${rp.id.split('/').slice(1).join('/')}/`} class="block p-4 border border-gray-200 rounded-lg hover:border-zen-200 hover:shadow-sm transition-all no-underline">
              <time class="text-xs text-gray-400" datetime={rp.data.date.toISOString().split('T')[0]}>
                {rp.data.date.toISOString().split('T')[0]}
              </time>
              <h3 class="font-medium text-gray-900 text-sm mt-1 line-clamp-2">{rp.data.title}</h3>
            </a>
          ))}
        </div>
        <a href={`/${lang}/blog/`} class="text-sm text-zen-500 hover:text-zen-600 no-underline">
          &larr; {lang === 'zh' ? '返回博客列表' : 'Back to blog'}
        </a>
      </div>
    )}
  </div>

  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      author: { '@type': 'Person', name: post.data.author },
      datePublished: post.data.date.toISOString().split('T')[0],
      dateModified: post.data.date.toISOString().split('T')[0],
    })}></script>
  </slot>
</BaseLayout>
