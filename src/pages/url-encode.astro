---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getTool } from '../utils/tools';
import { generateToolSEOMeta } from '../utils/seo';
import UrlEncoder from '../islands/UrlEncoder';

const tool = getTool('url-encode')!;
const seo = generateToolSEOMeta(tool);
---

<BaseLayout title={seo.title} description={tool.description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: '编码加密', href: '/category/crypto/' },
      { label: tool.title },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">在线{tool.title}工具</h1>
    <p class="text-gray-500 mb-8">{tool.description}</p>

    <UrlEncoder client:load />

    <section class="mt-12 prose max-w-none">
      <h2 class="text-xl font-semibold text-gray-900">如何使用{tool.title}工具</h2>
      <p class="text-gray-600">将需要处理的URL或文本粘贴到输入框中，选择"Encode URL"进行编码或"Decode URL"进行解码。编码可将中文、空格等特殊字符转换为%xx形式的URL安全格式，解码则反向还原。所有处理在浏览器端完成，保护您的数据隐私。</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">常见问题</h3>
      <div class="space-y-4">
        <div>
          <h4 class="font-medium text-gray-800">什么时候需要使用URL编码？</h4>
          <p class="text-gray-600">当URL中包含中文、空格、特殊符号等非ASCII字符时，需要进行URL编码才能正常传输。例如，在API请求参数中传递中文内容，或者构建包含特殊字符的查询字符串时，URL编码是必不可少的步骤。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">数据会上传到服务器吗？</h4>
          <p class="text-gray-600">不会。ToolZen所有工具都在浏览器本地运行，您的数据始终保留在您的设备上。URL编解码操作完全在您的浏览器中即时完成，无需任何网络通信。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">encodeURI和encodeURIComponent有什么区别？</h4>
          <p class="text-gray-600">encodeURI用于编码完整URL，保留URL中的特殊字符（如://?#），而encodeURIComponent会编码所有特殊字符。本工具使用encodeURIComponent提供最安全的编码方式，适合编码URL参数值。</p>
        </div>
      </div>
    </section>

    <RelatedTools current="url-encode" />
  </div>

  {seo.script.map(s => <script type={s.type} set:html={s.innerHTML}></script>)}
</BaseLayout>
