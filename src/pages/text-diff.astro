---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getTool } from '../utils/tools';
import { generateToolSEOMeta } from '../utils/seo';
import TextDiff from '../islands/TextDiff';

const tool = getTool('text-diff')!;
const seo = generateToolSEOMeta(tool);
---

<BaseLayout title={seo.title} description={tool.description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: '文本工具', href: '/category/text/' },
      { label: tool.title },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">在线{tool.title}工具</h1>
    <p class="text-gray-500 mb-8">{tool.description}</p>

    <TextDiff client:load />

    <section class="mt-12 prose max-w-none">
      <h2 class="text-xl font-semibold text-gray-900">如何使用{tool.title}工具</h2>
      <p class="text-gray-600">将两段文本分别粘贴到左侧（原始文本）和右侧（修改后文本）的输入框中，点击"Compare"按钮即可查看两段文本之间的差异。绿色高亮表示新增的内容，红色删除线表示被删除的内容。您可以在"Words"和"Lines"两种对比模式之间切换——"Words"模式按单词粒度对比，"Lines"模式按行粒度对比。所有对比运算均在浏览器本地完成，您的文本数据不会上传到任何服务器，安全可靠。</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">常见问题</h3>
      <div class="space-y-4">
        <div>
          <h4 class="font-medium text-gray-800">文本对比工具可以用来做什么？</h4>
          <p class="text-gray-600">文本对比工具可以帮助您快速发现两段文本之间的差异，常用于代码审查（对比代码修改前后）、文档版本对比（找出修改内容）、合同条款比对等场景。无论是开发者对比代码变更，还是编辑校对文章修改，都能提高工作效率。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">数据会上传到服务器吗？</h4>
          <p class="text-gray-600">不会。ToolZen所有工具都在浏览器本地运行，您的数据始终保留在您的设备上。我们不会收集、存储或传输您输入的任何内容。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">Words模式和Lines模式有什么区别？</h4>
          <p class="text-gray-600">Words模式按单词/字符粒度进行差异比较，适合精确查看每个字的增删改；Lines模式按行进行对比，适合查看代码文件或结构化文本的整体行级变更。建议对比代码时使用Lines模式，对比文章内容时使用Words模式。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">支持对比多大的文本？</h4>
          <p class="text-gray-600">文本对比工具在浏览器中运行，对于普通文本（数千行以内）的处理非常流畅。如果您的文本特别大（超过数万行），建议分段对比以确保浏览器性能。工具使用高效的差异算法，能够快速响应用户操作。</p>
        </div>
      </div>
    </section>

    <RelatedTools current="text-diff" />
  </div>

  {seo.script.map(s => <script type={s.type} set:html={s.innerHTML}></script>)}
</BaseLayout>
