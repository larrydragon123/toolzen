---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { getTool } from '../utils/tools';
import { generateToolSEOMeta } from '../utils/seo';
import MortgageCalculator from '../islands/MortgageCalculator';

const tool = getTool('mortgage-calculator')!;
const seo = generateToolSEOMeta(tool);
---

<BaseLayout title={seo.title} description={tool.description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: '计算器', href: '/category/calculators/' },
      { label: tool.title },
    ]} />

    <h1 class="text-3xl font-bold text-gray-900 mb-2">在线{tool.title}工具</h1>
    <p class="text-gray-500 mb-8">{tool.description}</p>

    <MortgageCalculator client:load />

    <section class="mt-12 prose max-w-none">
      <h2 class="text-xl font-semibold text-gray-900">如何使用{tool.title}工具</h2>
      <p class="text-gray-600">输入贷款金额、年利率和贷款年限，选择等额本息或等额本金还款方式，点击"计算"按钮即可获得详细的还款方案。支持查看每月的还款明细表，包括每月本金、利息和剩余贷款余额。所有计算均在浏览器本地完成，您的数据不会上传到任何服务器。</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">常见问题</h3>
      <div class="space-y-4">
        <div>
          <h4 class="font-medium text-gray-800">等额本息和等额本金有什么区别？</h4>
          <p class="text-gray-600">等额本息每月还款金额相同，前期利息占比高、本金占比低，适合收入稳定的借款人。等额本金每月还款金额逐月递减，前期还款压力较大但总利息更少，适合前期还款能力较强的借款人。您可以使用本计算器对比两种方式的差异。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">计算结果准确吗？</h4>
          <p class="text-gray-600">本计算器采用标准的等额本息和等额本金数学公式计算，结果与银行使用的计算方法一致。但实际贷款中银行可能会收取其他费用（如手续费、保险费等），最终还款金额以贷款合同为准。</p>
        </div>
        <div>
          <h4 class="font-medium text-gray-800">计算结果可以保存或打印吗？</h4>
          <p class="text-gray-600">您可以展开还款明细表查看完整的还款计划。如需保存，建议使用浏览器的打印功能（Ctrl+P）将结果导出为PDF，或直接截图保存。</p>
        </div>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6">房贷计算相关知识</h3>
      <p class="text-gray-600">房贷利率通常参考LPR（贷款市场报价利率）定价。目前中国5年期以上LPR利率约为3.6%至4.2%之间，具体取决于央行的最新调整。首套房贷款利率通常会低于二套房。建议在使用计算器前，先了解当地的最新房贷政策和利率水平，以获得更贴近实际的还款估算。</p>
    </section>

    <RelatedTools current="mortgage-calculator" />
  </div>

  {seo.script.map(s => <script type={s.type} set:html={s.innerHTML}></script>)}
</BaseLayout>
